/*
 * kernel/fs/vfs_bsd.c
 * Backward-compat string-based path lookup (vfs_lookup).
 * Full vnode lifecycle and mount management live in kernel/fs/vfs/.
 */
#include <kernel/cpu.h>
#include <kernel/sched.h>
#include <kernel/string.h>
#include <kernel/vfs/mount.h>
#include <kernel/vfs/namei.h>
#include <kernel/vfs/vnode.h>
#include <kernel/printk.h>

/*
 * vfs_lookup: walk a path component-by-component starting from start_vp.
 * Absolute paths (starting with '/') are anchored at the current process
 * root_vn, falling back to the global VFS root.
 */
int vfs_lookup(struct vnode *start_vp, const char *path, struct vnode **vpp,
               uid_t uid) {
  if (!path || !*path)
    return -EINVAL;

  struct process *cur = current_process;
  uint64_t lock_flags = 0;
  bool locked = false;

  if (cur) {
    spin_lock_irqsave(&cur->vfs_lock, &lock_flags);
    locked = true;
    pr_info("[C%d P%d %s] [TRACE] VFS: lookup %s\n", (int)hal_cpu_id(),
            cur->pid, cur->name, path);
  }

  struct vnode *current_vp = start_vp;
  char name[256];
  const char *p = path;

  if (*p == '/') {
    struct vnode *root = vfs_get_root();

    struct cpu_info *cpu = get_cpu_info();
    if (cpu && cpu->current_task && cpu->current_task->root_vn)
      root = cpu->current_task->root_vn;

    current_vp = root;
    while (*p == '/')
      p++;
  }

  if (!current_vp) {
    if (locked)
      spin_unlock_irqrestore(&cur->vfs_lock, lock_flags);
    return -ENOENT;
  }

  int err = 0;
  while (*p) {
    int i = 0;
    while (*p && *p != '/') {
      if (i < 255)
        name[i++] = *p;
      p++;
    }
    name[i] = '\0';
    while (*p == '/')
      p++;

    if (i == 0)
      break;

    struct componentname cn;
    cn.cn_nameptr = name;
    cn.cn_namelen = (size_t)i;
    cn.cn_uid = uid;
    cn.cn_flags = 0;

    if (!current_vp->v_op->vop_lookup) {
      err = -ENOTDIR;
      break;
    }

    if (current_vp->v_op->vop_access) {
      int acc_err = current_vp->v_op->vop_access(current_vp, 01, uid);
      if (acc_err != 0) {
        err = acc_err;
        break;
      }
    }

    struct vnode *next_vp = NULL;
    err = current_vp->v_op->vop_lookup(current_vp, &next_vp, &cn);
    if (err != 0)
      break;

    current_vp = next_vp;
  }

  if (locked)
    spin_unlock_irqrestore(&cur->vfs_lock, lock_flags);

  if (err == 0) {
    *vpp = current_vp;
  }
  return err;
}

int vfs_read(struct vnode *vp, void *buf, size_t len, off_t *off) {
  struct process *cur = current_process;
  uint64_t lock_flags = 0;
  bool locked = false;

  if (cur) {
    spin_lock_irqsave(&cur->vfs_lock, &lock_flags);
    locked = true;
    pr_info("[C%d P%d %s] [TRACE] VFS: read %d bytes at off %ld\n", (int)hal_cpu_id(),
             cur->pid, cur->name, (int)len, *off);
  }

  if (!vp->v_op->vop_read) {
    if (locked)
      spin_unlock_irqrestore(&cur->vfs_lock, lock_flags);
    return -ENOSYS;
  }

  int err = vp->v_op->vop_read(vp, buf, len, off);

  if (locked)
    spin_unlock_irqrestore(&cur->vfs_lock, lock_flags);
  return err;
}

int vfs_write(struct vnode *vp, const void *buf, size_t len, off_t *off) {
  struct process *cur = current_process;
  uint64_t lock_flags = 0;
  bool locked = false;

  if (cur) {
    spin_lock_irqsave(&cur->vfs_lock, &lock_flags);
    locked = true;
    pr_info("[C%d P%d %s] [TRACE] VFS: write %d bytes at off %ld\n", (int)hal_cpu_id(),
             cur->pid, cur->name, (int)len, *off);
  }

  if (!vp->v_op->vop_write) {
    if (locked)
      spin_unlock_irqrestore(&cur->vfs_lock, lock_flags);
    return -ENOSYS;
  }

  int err = vp->v_op->vop_write(vp, buf, len, off);

  if (locked)
    spin_unlock_irqrestore(&cur->vfs_lock, lock_flags);
  return err;
}

int vfs_readdir(struct vnode *vp, void *buf, size_t len, off_t *off) {
  struct process *cur = current_process;
  uint64_t lock_flags = 0;
  bool locked = false;

  if (cur) {
    spin_lock_irqsave(&cur->vfs_lock, &lock_flags);
    locked = true;
    pr_info("[C%d P%d %s] [TRACE] VFS: readdir %d bytes\n", (int)hal_cpu_id(),
            cur->pid, cur->name, (int)len);
  }

  if (!vp->v_op->vop_readdir) {
    if (locked)
      spin_unlock_irqrestore(&cur->vfs_lock, lock_flags);
    return -ENOSYS;
  }

  int err = vp->v_op->vop_readdir(vp, buf, len, off);

  if (locked)
    spin_unlock_irqrestore(&cur->vfs_lock, lock_flags);
  return err;
}
